---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  showReadingProgress?: boolean;
}

const { title, description, ogImage, showReadingProgress = false } = Astro.props;
const siteTitle = 'Muliminty';
const fullTitle = title === siteTitle ? title : `${title} — ${siteTitle}`;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="128x128" href="/favicon-128.png" />
  <title>{fullTitle}</title>
  <meta name="description" content={description || '一个前端开发者的公开时间线'} />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description || '一个前端开发者的公开时间线'} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description || '一个前端开发者的公开时间线'} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <!-- Loading bar styles -->
  <style>
    #loading-bar {
      position: fixed; top: 0; left: 0; z-index: 9999;
      height: 2px;
      background: var(--accent, #2563eb);
      width: 0;
      transition: width 0.4s ease, opacity 0.3s ease;
      opacity: 1;
    }
    #loading-bar.phased { width: 70%; transition: width 2s ease-out; }
    #loading-bar.done { width: 100%; opacity: 0; transition: width 0.3s ease, opacity 0.3s ease; }

    /* Reading progress: 不支持 scroll-timeline 时隐藏；支持时动画驱动 */
    #loading-bar.reading {
      width: 0;
      opacity: 0;
    }
    @supports (animation-timeline: scroll()) {
      #loading-bar.reading {
        animation: read-progress linear;
        animation-timeline: scroll(root);
      }
      @keyframes read-progress {
        0%   { width: 0%;   opacity: 1; }
        100% { width: 100%; opacity: 1; }
      }
      /* 移动端禁用 scroll-timeline，避免 iOS Safari 滚动兼容问题 */
      @media (max-width: 600px) {
        #loading-bar.reading {
          animation: none;
          width: 0;
          opacity: 0;
        }
      }
    }





  </style>

  <!-- Curtain styles must be global (slats created dynamically by JS) -->
  <style is:global>
  .curtain-layer {
    position: fixed; inset: 0; z-index: 9998; pointer-events: none;
    display: flex; flex-direction: column;
  }
  .curtain-slat {
    flex: 1;
    background: #fff;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  </style>
</head>
<body>
  <div id="loading-bar" data-reading={showReadingProgress ? "true" : "false"}></div>
  <div class="curtain-layer" id="curtain-layer" aria-hidden="true"></div>
  <slot />

  <!-- Dot grid parallax -->
  <script>
    (function() {
      if (window.matchMedia('(max-width: 600px)').matches) return;
      var x = 0, y = 0, tx = 0, ty = 0;
      document.addEventListener('mousemove', function(e) {
        x = (e.clientX / window.innerWidth - 0.5) * 24;
        y = (e.clientY / window.innerHeight - 0.5) * 24;
      });
      function tick() {
        tx += (x - tx) * 0.08;
        ty += (y - ty) * 0.08;
        var el = document.querySelector('body');
        if (el) el.style.setProperty('--dot-x', tx + 'px');
        if (el) el.style.setProperty('--dot-y', ty + 'px');
        requestAnimationFrame(tick);
      }
      tick();
    })();
  </script>

  <!-- Custom cursor -->
  <script>
    (function() {
      if (window.matchMedia('(max-width: 600px)').matches) return;
      var dot = document.createElement('div');
      dot.className = 'cursor-dot';
      document.body.appendChild(dot);

      var trail = document.createElement('div');
      trail.className = 'cursor-trail';
      document.body.appendChild(trail);

      var mx = 0, my = 0, tx = 0, ty = 0;
      document.addEventListener('mousemove', function(e) {
        mx = e.clientX; my = e.clientY;
        dot.style.left = mx + 'px';
        dot.style.top = my + 'px';
      });

      function trailTick() {
        tx += (mx - tx) * 0.15;
        ty += (my - ty) * 0.15;
        trail.style.left = tx + 'px';
        trail.style.top = ty + 'px';
        requestAnimationFrame(trailTick);
      }
      trailTick();
      // Hover detection
      document.querySelectorAll('a, button, .card-hover, .filter-tab, .pill-link, .heatmap-day').forEach(function(el) {
        el.addEventListener('mouseenter', function() { dot.classList.add('hovering'); });
        el.addEventListener('mouseleave', function() { dot.classList.remove('hovering'); });
      });
    })();
  </script>

  <script>
    (function() {
      var bar = document.getElementById('loading-bar');
      if (!bar) return;

      // Phase 1: fast start
      bar.style.width = '20%';

      // Phase 2: slow trickle
      setTimeout(function() { bar.classList.add('phased'); }, 300);

      // Phase 3: transition to reading progress bar on page load
      var done = false;
      function finish() {
        if (done) return; done = true;
        bar.classList.remove('phased');
        bar.classList.add('done');
        setTimeout(function() {
          if (bar.parentNode) {
          bar.classList.remove('done', 'reading');
          if (bar.getAttribute('data-reading') === 'true') {
            bar.classList.remove('done');
            bar.classList.add('reading');
          } else {
            bar.parentNode.removeChild(bar);
          }
        }
        }, 400);
      }
      window.addEventListener('load', finish);
      // Fallback: hide after 5s anyway
      setTimeout(finish, 5000);

      // Navigation API: detect new navigations
      if (window.navigation) {
        window.navigation.addEventListener('navigate', function() {
          bar.style.width = '0';
          bar.classList.remove('done', 'reading');
          bar.style.opacity = '1';
          setTimeout(function() { bar.style.width = '20%'; }, 50);
          setTimeout(function() { bar.classList.add('phased'); }, 300);
        });
        window.navigation.addEventListener('navigatesuccess', finish);
        window.navigation.addEventListener('navigateerror', finish);
      }
    })();
  </script>

  <!-- Scroll reveal -->
  <script>
    (function() {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var items = entry.target.querySelectorAll(':scope > *');
            items.forEach(function(item, i) {
              item.classList.add('reveal');
              setTimeout(function() {
                item.classList.add('visible');
              }, i * 60);
            });
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

      document.querySelectorAll('.entrance-container').forEach(function(el) {
        observer.observe(el);
      });
    })();
  </script>

  <!-- 3D card tilt -->
  <script>
    (function() {
      document.querySelectorAll('.card-tilt').forEach(function(card) {
        card.addEventListener('mousemove', function(e) {
          var rect = card.getBoundingClientRect();
          var x = (e.clientX - rect.left) / rect.width - 0.5;
          var y = (e.clientY - rect.top) / rect.height - 0.5;
          card.style.transform = 'perspective(800px) rotateY(' + (x * 6) + 'deg) rotateX(' + (-y * 4) + 'deg)';
        });
        card.addEventListener('mouseleave', function() {
          card.style.transform = 'perspective(800px) rotateY(0deg) rotateX(0deg)';
        });
      });
    })();
  </script>

  <!-- Curtain theme toggle -->
  <script>
    (function() {
      var N = 8;
      var layer = document.getElementById('curtain-layer');
      if (!layer) return;

      for (var i = 0; i < N; i++) {
        var s = document.createElement('div');
        s.className = 'curtain-slat';
        s.style.transition = 'transform 0.4s cubic-bezier(0.4, 0, 0.2, 1)';
        s.style.transform = 'scaleX(0)';
        s.style.transformOrigin = 'left';
        s.style.transitionDelay = (i * 0.05) + 's';
        layer.appendChild(s);
      }

      var btn = document.getElementById('theme-toggle');
      var icon = btn ? btn.querySelector('.theme-icon') : null;
      var KEY = 'theme';
      var slats = layer.querySelectorAll('.curtain-slat');
      var busy = false;

      function resolveTheme() {
        var stored = localStorage.getItem(KEY);
        if (stored === 'dark' || stored === 'light') return stored;
        return 'dark';
      }

      function setDOM(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        if (icon) icon.textContent = theme === 'dark' ? '\uD83C\uDF19' : '\u2600\uFE0F';
        localStorage.setItem(KEY, theme);
      }

      // Init — no animation
      setDOM(resolveTheme());

      btn.addEventListener('click', function() {
        if (busy) return;
        var goingDark = resolveTheme() === 'light';
        busy = true;

        // 幕布颜色 = 目标主题背景色，slat 覆盖全屏后 setDOM 切换，
        //   颜色完全一致 → 无闪烁
        slats.forEach(function(s) {
          s.style.background = goingDark ? '#1c1917' : '#fafaf8';
          s.style.transformOrigin = goingDark ? 'left' : 'right';
          s.style.transform = 'scaleX(1)';
        });

        var last = slats[slats.length - 1];
        last.addEventListener('transitionend', function handler() {
          last.removeEventListener('transitionend', handler);
          setDOM(goingDark ? 'dark' : 'light');
          // 瞬间缩回 scaleX(0)：关 transition → 设 transform → 开 transition
          slats.forEach(function(s) {
            s.style.transition = 'none';
            s.style.transform = 'scaleX(0)';
            s.style.background = '';
            s.style.transformOrigin = '';
          });
          layer.offsetHeight;
          // 恢复 transition 和 delay（setProperty('transition','none') 覆盖了 delay）
          slats.forEach(function(s, i) {
            s.style.transition = 'transform 0.4s cubic-bezier(0.4, 0, 0.2, 1)';
            s.style.transitionDelay = (i * 0.05) + 's';
          });
          busy = false;
        });
      });

      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
        if (!localStorage.getItem(KEY) && !busy) {
          setDOM(e.matches ? 'dark' : 'light');
        }
      });
    })();
  </script>
</body>
</html>
