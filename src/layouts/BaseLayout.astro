---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const siteTitle = 'Muliminty';
const fullTitle = title === siteTitle ? title : `${title} — ${siteTitle}`;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description || '一个前端开发者的公开时间线'} />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description || '一个前端开发者的公开时间线'} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description || '一个前端开发者的公开时间线'} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <!-- Loading bar styles -->
  <style>
    #loading-bar {
      position: fixed; top: 0; left: 0; z-index: 9999;
      height: 2px;
      background: var(--accent, #2563eb);
      width: 0;
      transition: width 0.4s ease, opacity 0.3s ease;
      opacity: 1;
    }
    #loading-bar.phased { width: 70%; transition: width 2s ease-out; }
    #loading-bar.done { width: 100%; opacity: 0; transition: width 0.3s ease, opacity 0.3s ease; }
  </style>
</head>
<body>
  <div id="loading-bar"></div>
  <slot />

  <script>
    (function() {
      var bar = document.getElementById('loading-bar');
      if (!bar) return;

      // Phase 1: fast start
      bar.style.width = '20%';

      // Phase 2: slow trickle
      setTimeout(function() { bar.classList.add('phased'); }, 300);

      // Phase 3: hide on page load
      var done = false;
      function finish() {
        if (done) return; done = true;
        bar.classList.remove('phased');
        bar.classList.add('done');
        setTimeout(function() {
          if (bar.parentNode) bar.parentNode.removeChild(bar);
        }, 400);
      }
      window.addEventListener('load', finish);
      // Fallback: hide after 5s anyway
      setTimeout(finish, 5000);

      // Navigation API: detect new navigations
      if (window.navigation) {
        window.navigation.addEventListener('navigate', function() {
          bar.style.width = '0';
          bar.classList.remove('done');
          bar.style.opacity = '1';
          setTimeout(function() { bar.style.width = '20%'; }, 50);
          setTimeout(function() { bar.classList.add('phased'); }, 300);
        });
        window.navigation.addEventListener('navigatesuccess', finish);
        window.navigation.addEventListener('navigateerror', finish);
      }
    })();
  </script>
</body>
</html>
