---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const siteTitle = 'Muliminty';
const fullTitle = title === siteTitle ? title : `${title} — ${siteTitle}`;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" sizes="32x32" href="/home/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="128x128" href="/home/favicon-128.png" />
  <title>{fullTitle}</title>
  <meta name="description" content={description || '一个前端开发者的公开时间线'} />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description || '一个前端开发者的公开时间线'} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description || '一个前端开发者的公开时间线'} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <!-- Loading bar styles -->
  <style>
    #loading-bar {
      position: fixed; top: 0; left: 0; z-index: 9999;
      height: 2px;
      background: var(--accent, #2563eb);
      width: 0;
      transition: width 0.4s ease, opacity 0.3s ease;
      opacity: 1;
    }
    #loading-bar.phased { width: 70%; transition: width 2s ease-out; }
    #loading-bar.done { width: 100%; opacity: 0; transition: width 0.3s ease, opacity 0.3s ease; }

  /* Curtain slats — 幕布扫描动画层 */
  .curtain-layer {
    position: fixed; inset: 0; z-index: 9998; pointer-events: none;
    display: flex; flex-direction: column;
    clip-path: inset(0 100% 0 0);
  }
  .curtain-layer.active { clip-path: inset(0 0 0 0); transition: clip-path 0.55s cubic-bezier(0.4, 0, 0.2, 1); }
  .curtain-slat {
    flex: 1;
    background: #1c1917;
    transform: scaleX(0);
    transform-origin: left;
  }
  .curtain-layer.active .curtain-slat {
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .curtain-layer[data-reverse] .curtain-slat {
    transform-origin: right;
    transform: scaleX(1);
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .curtain-layer[data-reverse].active .curtain-slat {
    transform: scaleX(0);
  }
  </style>
</head>
<body>
  <div id="loading-bar"></div>
  <div class="curtain-layer" id="curtain-layer" aria-hidden="true"></div>
  <slot />

  <!-- Dot grid parallax -->
  <script>
    (function() {
      var x = 0, y = 0, tx = 0, ty = 0;
      document.addEventListener('mousemove', function(e) {
        x = (e.clientX / window.innerWidth - 0.5) * 24;
        y = (e.clientY / window.innerHeight - 0.5) * 24;
      });
      function tick() {
        tx += (x - tx) * 0.08;
        ty += (y - ty) * 0.08;
        var el = document.querySelector('body');
        if (el) el.style.setProperty('--dot-x', tx + 'px');
        if (el) el.style.setProperty('--dot-y', ty + 'px');
        requestAnimationFrame(tick);
      }
      tick();
    })();
  </script>

  <!-- Custom cursor -->
  <script>
    (function() {
      var dot = document.createElement('div');
      dot.className = 'cursor-dot';
      document.body.appendChild(dot);

      var trail = document.createElement('div');
      trail.className = 'cursor-trail';
      document.body.appendChild(trail);

      var mx = 0, my = 0, tx = 0, ty = 0;
      document.addEventListener('mousemove', function(e) {
        mx = e.clientX; my = e.clientY;
        dot.style.left = mx + 'px';
        dot.style.top = my + 'px';
      });

      function trailTick() {
        tx += (mx - tx) * 0.15;
        ty += (my - ty) * 0.15;
        trail.style.left = tx + 'px';
        trail.style.top = ty + 'px';
        requestAnimationFrame(trailTick);
      }
      trailTick();
      // Hover detection
      document.querySelectorAll('a, button, .card-hover, .filter-tab, .pill-link, .heatmap-day').forEach(function(el) {
        el.addEventListener('mouseenter', function() { dot.classList.add('hovering'); });
        el.addEventListener('mouseleave', function() { dot.classList.remove('hovering'); });
      });
    })();
  </script>

  <script>
    (function() {
      var bar = document.getElementById('loading-bar');
      if (!bar) return;

      // Phase 1: fast start
      bar.style.width = '20%';

      // Phase 2: slow trickle
      setTimeout(function() { bar.classList.add('phased'); }, 300);

      // Phase 3: hide on page load
      var done = false;
      function finish() {
        if (done) return; done = true;
        bar.classList.remove('phased');
        bar.classList.add('done');
        setTimeout(function() {
          if (bar.parentNode) bar.parentNode.removeChild(bar);
        }, 400);
      }
      window.addEventListener('load', finish);
      // Fallback: hide after 5s anyway
      setTimeout(finish, 5000);

      // Navigation API: detect new navigations
      if (window.navigation) {
        window.navigation.addEventListener('navigate', function() {
          bar.style.width = '0';
          bar.classList.remove('done');
          bar.style.opacity = '1';
          setTimeout(function() { bar.style.width = '20%'; }, 50);
          setTimeout(function() { bar.classList.add('phased'); }, 300);
        });
        window.navigation.addEventListener('navigatesuccess', finish);
        window.navigation.addEventListener('navigateerror', finish);
      }
    })();
  </script>

  <!-- Scroll reveal -->
  <script>
    (function() {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var items = entry.target.querySelectorAll(':scope > *');
            items.forEach(function(item, i) {
              item.classList.add('reveal');
              setTimeout(function() {
                item.classList.add('visible');
              }, i * 60);
            });
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

      document.querySelectorAll('.entrance-container').forEach(function(el) {
        observer.observe(el);
      });
    })();
  </script>

  <!-- 3D card tilt -->
  <script>
    (function() {
      document.querySelectorAll('.card-tilt').forEach(function(card) {
        card.addEventListener('mousemove', function(e) {
          var rect = card.getBoundingClientRect();
          var x = (e.clientX - rect.left) / rect.width - 0.5;
          var y = (e.clientY - rect.top) / rect.height - 0.5;
          card.style.transform = 'perspective(800px) rotateY(' + (x * 6) + 'deg) rotateX(' + (-y * 4) + 'deg)';
        });
        card.addEventListener('mouseleave', function() {
          card.style.transform = 'perspective(800px) rotateY(0deg) rotateX(0deg)';
        });
      });
    })();
  </script>

  <!-- Curtain theme toggle -->
  <script>
    (function() {
      var N = 8;
      var layer = document.getElementById('curtain-layer');
      if (!layer) return;

      // Build slats
      for (var i = 0; i < N; i++) {
        var s = document.createElement('div');
        s.className = 'curtain-slat';
        s.style.transitionDelay = (i * 0.04) + 's';
        layer.appendChild(s);
      }

      var btn = document.getElementById('theme-toggle');
      var icon = btn ? btn.querySelector('.theme-icon') : null;
      var STORAGE_KEY = 'theme';

      function getTheme() {
        var stored = localStorage.getItem(STORAGE_KEY);
        if (stored === 'dark' || stored === 'light') return stored;
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }

      function applyTheme(theme, animate) {
        var isDark = theme === 'dark';
        document.documentElement.setAttribute('data-theme', theme);
        if (icon) icon.textContent = isDark ? '🌙' : '☀️';
        localStorage.setItem(STORAGE_KEY, theme);
        if (!animate) return;

        var slats = layer.querySelectorAll('.curtain-slat');

        if (isDark) {
          // light → dark: slats expand left-to-right
          layer.removeAttribute('data-reverse');
          slats.forEach(function(s) { s.style.transform = 'scaleX(1)'; });
          layer.classList.add('active');
          var last = slats[slats.length - 1];
          last.addEventListener('transitionend', function handler() {
            last.removeEventListener('transitionend', handler);
            layer.classList.remove('active');
            slats.forEach(function(s) { s.style.transform = ''; });
          });
        } else {
          // dark → light: slats contract right-to-left
          layer.setAttribute('data-reverse', '');
          void layer.offsetWidth;
          slats.forEach(function(s) { s.style.transform = 'scaleX(1)'; });
          layer.classList.add('active');
          void layer.offsetWidth;
          slats.forEach(function(s) { s.style.transform = 'scaleX(0)'; });
          var last = slats[slats.length - 1];
          last.addEventListener('transitionend', function handler() {
            last.removeEventListener('transitionend', handler);
            layer.classList.remove('active');
            layer.removeAttribute('data-reverse');
            slats.forEach(function(s) { s.style.transform = ''; });
          });
        }
      }

      // Init
      var current = getTheme();
      applyTheme(current, false);

      if (btn) {
        btn.addEventListener('click', function() {
          var next = getTheme() === 'dark' ? 'light' : 'dark';
          applyTheme(next, true);
        });
      }

      // Listen for system theme changes (only if user hasn't set a preference)
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
        if (!localStorage.getItem(STORAGE_KEY)) {
          applyTheme(e.matches ? 'dark' : 'light', true);
        }
      });
    })();
  </script>
</body>
</html>
