---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import MomentCard from '../../components/MomentCard.astro';
import { loadAllContent } from '../../lib/content/loadContent';

const base = import.meta.env.BASE_URL;
const { items } = await loadAllContent();

const filterTabs = [
  { key: 'all', label: '全部' },
  { key: 'article', label: '文章' },
  { key: 'moment', label: '动态' },
];

// Group by date — always render all items, filter via client JS
const grouped = new Map<string, typeof items>();
for (const item of items) {
  const date = item.publishedAt.slice(0, 10);
  if (!grouped.has(date)) grouped.set(date, []);
  grouped.get(date)!.push(item);
}
---

<BaseLayout title="近况">
  <div class="container entrance-container">
    <SiteHeader />

    <div class="filter-tabs">
      {filterTabs.map(tab => (
        <a
          href={tab.key === 'all' ? `${base}updates/` : `${base}updates/?filter=${tab.key}`}
          class="filter-tab"
          data-filter={tab.key}
        >
          {tab.label}
        </a>
      ))}
    </div>

    {Array.from(grouped.entries()).map(([date, dayItems]) => (
      <div class="day-group">
        <div class="day-sep">{date}</div>
        {dayItems.map(item => (
          item.kind === 'article'
            ? <div data-kind="article"><ArticleCard article={item} showPinned /></div>
            : <div data-kind="moment"><MomentCard moment={item} /></div>
        ))}
      </div>
    ))}

    <p class="empty-text" hidden>暂无内容</p>
  </div>
</BaseLayout>

<style>
  .filter-tabs {
    display: flex; gap: 4px;
    margin-bottom: 32px;
  }
  .filter-tab {
    font-size: 13px;
    padding: 5px 14px;
    border-radius: 20px;
    color: var(--text-muted);
    text-decoration: none;
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: all 0.15s;
  }
  .filter-tab:hover { color: var(--text); border-color: #c4b5b0; text-decoration: none; }
  .filter-tab.active { color: var(--bg-card); background: var(--text); border-color: var(--text); }

  .day-sep {
    font-size: 12px; color: var(--text-muted);
    font-family: var(--font-mono);
    padding: 16px 0 8px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px; font-weight: 500;
  }
  .day-sep:first-child { padding-top: 0; }

  .empty-text { font-size: 13px; color: var(--text-muted); text-align: center; padding: 40px 0; }
</style>

<script>
  (function() {
    var tabs = document.querySelectorAll('.filter-tab');
    var groups = document.querySelectorAll('.day-group');
    var empty = document.querySelector('.empty-text');

    function getFilter() {
      var m = window.location.search.match(/filter=(\w+)/);
      return m ? m[1] : 'all';
    }

    function applyFilter(key) {
      // Update tab active states
      tabs.forEach(function(t) {
        t.classList.toggle('active', t.dataset.filter === key);
      });

      // Show/hide cards
      var hasVisible = false;
      groups.forEach(function(group) {
        var cards = group.querySelectorAll('[data-kind]');
        var groupVisible = false;
        cards.forEach(function(card) {
          var show = key === 'all' || card.dataset.kind === key;
          card.hidden = !show;
          if (show) groupVisible = true;
        });
        group.hidden = !groupVisible;
        if (groupVisible) hasVisible = true;
      });

      if (empty) empty.hidden = hasVisible;
    }

    // Init from URL
    applyFilter(getFilter());

    // Handle tab clicks — update URL without full reload when already on this page
    // (Link navigation is the primary flow; init handles the state on load)
  })();
</script>
