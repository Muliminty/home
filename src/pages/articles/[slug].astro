---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import GiscusComments from '../../components/GiscusComments.astro';
import IssueSource from '../../components/IssueSource.astro';
import ArticleLightbox from '../../components/ArticleLightbox.astro';
import { loadAllContent } from '../../lib/content/loadContent';
import type { ArticleUpdate } from '../../lib/content/types';
import { unified } from 'unified';
import remarkParse from 'remark-parse';
import remarkGfm from 'remark-gfm';
import remarkRehype from 'remark-rehype';
import rehypeStringify from 'rehype-stringify';
import rehypePrettyCode from 'rehype-pretty-code';
import rehypeSlug from 'rehype-slug';
import GithubSlugger from 'github-slugger';

export async function getStaticPaths() {
  const { items } = await loadAllContent();
  return items
    .filter(i => i.kind === 'article')
    .map(a => ({ params: { slug: (a as ArticleUpdate).slug } }));
}

const base = import.meta.env.BASE_URL;
const { slug } = Astro.params;
const { items } = await loadAllContent();
const article = items.find(i => i.kind === 'article' && (i as ArticleUpdate).slug === slug) as ArticleUpdate | undefined;

if (!article) {
  return Astro.redirect(base + '404');
}

const bodyHtml = await unified()
  .use(remarkParse)
  .use(remarkGfm)
  .use(remarkRehype, { allowDangerousHtml: false })
  .use(rehypePrettyCode, { theme: { light: 'github-light', dark: 'github-dark' } })
  .use(rehypeSlug)
  .use(rehypeStringify)
  .process(article.body);

// Extract headings from body for TOC
const slugger = new GithubSlugger();
const headingRegex = /^(#{2,3})\s+(.+)$/gm;
const headings: Array<{ id: string; text: string; level: number }> = [];
let match;
while ((match = headingRegex.exec(article.body)) !== null) {
  const text = match[2];
  const id = slugger.slug(text);
  headings.push({ id, text, level: match[1].length });
}

const description = article.description;
const cover = article.cover;
---

<BaseLayout title={article.title} description={description} ogImage={cover} showReadingProgress={true}>
  <button class="theme-float" id="theme-toggle" aria-label="切换主题">
    <span class="theme-icon">🌙</span>
  </button>
  <div class="container-wide">
    <TableOfContents headings={headings} />
    <div class="article-column">
      <a class="back-link" href={`${base}updates/`}>&larr; 近况</a>

      <header class="article-header">
        <span class="kind-badge">ARTICLE</span>
        <h1>{article.title}</h1>
        <p class="desc">{description}</p>
        <div class="meta">
          <span>{article.publishedAt.slice(0, 10)}</span>
          <span>&middot;</span>
          <span>阅读 {article.readingTime} 分钟</span>
        </div>
        <div class="tags">
          {article.tags.map(tag => <a href={`${base}tags/${tag}`} class="tag">#{tag}</a>)}
        </div>
      </header>

      {cover && <img class="cover" src={cover} alt="" />}

      <div class="article-body">
        <Fragment set:html={bodyHtml.toString()} />
      </div>

      <IssueSource issueUrl={article.issueUrl} issueNumber={article.number} />
      <ArticleLightbox />
      <GiscusComments />
    </div>
  </div>
</BaseLayout>

<style>
  .article-column { min-width: 0; max-width: 600px; }
  .back-link { display: inline-block; font-size: 13px; color: var(--text-muted); text-decoration: none; margin-bottom: 40px; }
  .back-link:hover { color: var(--accent); }
  .article-header { margin-bottom: 32px; }
  .kind-badge { display: inline-block; font-size: 10px; font-weight: 600; letter-spacing: 0.06em; color: var(--accent); border: 1px solid var(--accent); padding: 2px 8px; border-radius: 3px; margin-bottom: 16px; }
  .article-header h1 { font-size: 24px; font-weight: 700; line-height: 1.35; margin-bottom: 12px; }
  .desc { font-size: 15px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 20px; }
  .meta { font-size: 13px; color: var(--text-muted); display: flex; gap: 16px; align-items: center; }
  .tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 14px; }
  .tag { font-size: 11px; color: var(--accent); text-decoration: none; }
  .cover { width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: 8px; margin-bottom: 32px; background: var(--bg-card); }

  /* ── Article Body ── */
  .article-body { font-size: 15px; line-height: 1.85; color: var(--text); }
  .article-body :global(h2) {
    font-size: 20px; font-weight: 700; line-height: 1.35;
    margin: 48px 0 16px; padding-bottom: 8px;
    color: var(--heading-color);
    border-bottom: 1px solid var(--border);
  }
  .article-body :global(h3) {
    font-size: 17px; font-weight: 600; line-height: 1.4;
    margin: 36px 0 12px;
    color: var(--heading-color);
  }
  .article-body :global(h4) {
    font-size: 15px; font-weight: 600;
    margin: 24px 0 8px;
    color: var(--heading-color);
  }
  .article-body :global(p) { margin-bottom: 20px; }
  .article-body :global(a) { color: var(--accent); text-decoration: none; }
  .article-body :global(a:hover) { text-decoration: underline; }
  .article-body :global(strong) { font-weight: 600; color: var(--heading-color); }
  .article-body :global(ul), .article-body :global(ol) { margin: 16px 0 16px 20px; }
  .article-body :global(li) { margin-bottom: 8px; }
  .article-body :global(li > ul), .article-body :global(li > ol) { margin-top: 8px; margin-bottom: 0; }
  .article-body :global(blockquote) {
    margin: 24px 0; padding: 12px 16px;
    border-left: 4px solid var(--blockquote-accent);
    background: var(--blockquote-bg);
    border-radius: 0 6px 6px 0;
    color: var(--text-secondary);
  }
  .article-body :global(blockquote) :global(p:last-child) { margin-bottom: 0; }
  .article-body :global(hr) {
    border: none; height: 1px;
    background: var(--hr-color);
    margin: 48px 0;
  }
  .article-body :global(code) {
    font-family: var(--font-mono); font-size: 13px;
    background: var(--code-bg); padding: 2px 6px;
    border-radius: 4px;
  }
  .article-body :global(pre) {
    background: var(--pre-bg);
    border: 1px solid var(--pre-border);
    border-radius: 8px; padding: 20px;
    overflow-x: auto; margin: 24px 0;
    font-size: 13px; line-height: 1.7;
  }
  .article-body :global(pre) :global(code) {
    background: none; padding: 0; font-size: inherit; border-radius: 0;
  }
  .article-body :global(table) {
    width: 100%; border-collapse: collapse;
    margin: 24px 0; font-size: 14px;
  }
  .article-body :global(th), .article-body :global(td) {
    padding: 8px 12px; text-align: left;
    border: 1px solid var(--table-border);
  }
  .article-body :global(th) { background: var(--table-head-bg); font-weight: 600; }
  .article-body :global(tr:nth-child(even)) :global(td) { background: var(--table-stripe); }
  .article-body :global(img) { max-width: 100%; border-radius: 8px; margin: 16px 0; }
  .article-body :global(del) { color: var(--text-muted); }

  /* 浮动主题切换按钮 */
  .theme-float {
    position: fixed; top: 20px; right: 20px; z-index: 100;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .theme-float:hover {
    transform: scale(1.1);
    box-shadow: 0 2px 12px var(--shadow-color);
  }
  .theme-icon {
    font-size: 16px; line-height: 1;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .theme-float:active .theme-icon { transform: rotate(180deg) scale(0.9); }

  @media (max-width: 600px) {
    .article-header h1 { font-size: 20px; }
    .article-body { font-size: 14px; }
    .cover { border-radius: 4px; }
    .theme-float { top: 12px; right: 12px; width: 32px; height: 32px; }
    .theme-icon { font-size: 14px; }
  }
</style>

<script>
  // TOC 滚动联动：基于滚动位置找"当前章节"（最近经过的标题）
  const tocLinks = document.querySelectorAll('.toc-list a');
  const headings = document.querySelectorAll('.article-body h2[id], .article-body h3[id]');
  if (tocLinks.length && headings.length) {
    const THRESHOLD = 120; // 固定 header 高度 + 一点余量
    let pill = null;
    let userScrolling = false;
    let userScrollTimer = 0;

    // Pill 指示器仅在桌面端创建
    if (window.matchMedia('(min-width: 961px)').matches) {
      const nav = document.getElementById('toc-nav');
      if (nav) {
        pill = document.createElement('div');
        pill.className = 'toc-pill';
        nav.appendChild(pill);
      }
    }

    const isMobile = !window.matchMedia('(min-width: 961px)').matches;

    // 点击 TOC 链接时临时禁用自动跟踪
    tocLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        userScrolling = true;
        clearTimeout(userScrollTimer);
        userScrollTimer = setTimeout(() => { userScrolling = false; }, 2000);
        // 移动端用 JS 控制滚动，避免原生锚点跳转干扰用户手势
        if (isMobile) {
          e.preventDefault();
          const id = link.getAttribute('href').slice(1);
          const target = document.getElementById(id);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });

    function update() {
      // 找最近经过 threshold 的标题（倒序遍历）
      let active = null;
      for (let i = headings.length - 1; i >= 0; i--) {
        if (headings[i].getBoundingClientRect().top <= THRESHOLD) {
          active = headings[i];
          break;
        }
      }
      // 清除所有高亮
      tocLinks.forEach(l => l.classList.remove('active'));
      // 高亮当前章节
      if (active) {
        const link = document.querySelector(`.toc-list a[href="#${active.id}"]`);
        if (link) {
          link.classList.add('active');
          // Pill 定位（仅桌面端）
          if (pill && !userScrolling) {
            const linkRect = link.getBoundingClientRect();
            const navRect = document.getElementById('toc-nav').getBoundingClientRect();
            pill.style.top = (linkRect.top - navRect.top + linkRect.height / 2 - 9) + 'px';
          }
          // 桌面端 sticky 侧栏自动滚动跟随
          if (!isMobile && !userScrolling) {
            const nav = document.getElementById('toc-nav');
            const linkTop = link.getBoundingClientRect().top - nav.getBoundingClientRect().top;
            if (linkTop < 0 || linkTop > nav.clientHeight - 30) {
              link.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
            }
          }
        }
      }
    }

    let rafPending = false;
    window.addEventListener('scroll', () => {
      if (!rafPending) {
        requestAnimationFrame(() => {
          update();
          rafPending = false;
        });
        rafPending = true;
      }
    }, { passive: true });
    update();
  }
</script>
