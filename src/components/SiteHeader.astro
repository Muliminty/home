---
import { siteConfig } from '../config';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname.replace(/\/$/, '');
const navItems = [
  { href: 'updates/', label: '近况', match: currentPath.startsWith(base + 'updates') },
  { href: 'about/', label: '关于', match: currentPath.startsWith(base + 'about') },
];

const isHome = currentPath === base || currentPath === base.slice(0, -1);
---

<header class="site-header">
  <a href={base} class="header-brand">
    <span class="header-avatar">
      <img src={`${base}avatar.jpeg`} alt={siteConfig.title} width="36" height="36" />
    </span>
    <span class="header-name">{siteConfig.title}</span>
  </a>
  <nav class="nav">
    {navItems.map(item => (
      <a href={base + item.href} class:list={[{ active: item.match }]}>{item.label}</a>
    ))}
  </nav>
</header>

{isHome && (
<div class="greeting">
  <span class="greeting-text" id="greeting-text"></span>
  <span class="greeting-cursor">|</span>
</div>
)}

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }
  .header-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
  }
  .header-brand:hover { text-decoration: none; }
  .header-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    border: 2px solid var(--border);
    flex-shrink: 0;
  }
  .header-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .header-name { font-size: 16px; font-weight: 600; }
  .nav { display: flex; gap: 16px; }
  .nav a {
    font-size: 13px; color: var(--text-muted); text-decoration: none;
    padding: 4px 0; border-bottom: 2px solid transparent; transition: all 0.15s;
  }
  .nav a:hover, .nav a.active { color: var(--text); border-bottom-color: var(--text-muted); }
  .greeting { margin-bottom: 40px; }
  .greeting-text { font-size: 20px; font-weight: 600; color: var(--text); }
  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .greeting-cursor {
    color: var(--accent);
    font-weight: 300;
    animation: none;
  }
</style>

<script>
  (function() {
    var el = document.getElementById('greeting-text');
    if (!el) return;
    var text = '你好，这里是 Muliminty 的个人站点';
    var i = 0;
    var cursor = document.querySelector('.greeting-cursor');
    function type() {
      if (i < text.length) {
        el.textContent += text.charAt(i);
        i++;
        setTimeout(type, 80 + Math.random() * 40);
      } else {
        if (cursor) {
          cursor.style.animation = 'cursor-blink 1s step-end infinite';
        }
      }
    }
    setTimeout(type, 400);
  })();
</script>
