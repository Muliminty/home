<div class="giscus"></div>

<style>
  .giscus { margin-top: 48px; }
</style>

<script is:inline>
  (function() {
    var container = document.querySelector('.giscus');
    if (!container) return;

    // data-theme 已由 <head> 同步脚本保证存在，直接读
    var currentTheme = document.documentElement.getAttribute('data-theme');

    var script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.setAttribute('data-repo', 'muliminty/home');
    script.setAttribute('data-repo-id', 'R_kgDOMi9Ggw');
    script.setAttribute('data-category', 'General');
    script.setAttribute('data-category-id', 'DIC_kwDOMi9Gg84C8Quh');
    script.setAttribute('data-mapping', 'pathname');
    script.setAttribute('data-strict', '0');
    script.setAttribute('data-reactions-enabled', '1');
    script.setAttribute('data-emit-metadata', '0');
    script.setAttribute('data-input-position', 'top');
    script.setAttribute('data-theme', currentTheme === 'light' ? 'light' : 'dark');
    script.setAttribute('data-lang', 'zh-CN');
    script.setAttribute('crossorigin', 'anonymous');
    script.async = true;
    container.appendChild(script);

    // 主题切换时通过 postMessage 同步 Giscus，带重试（iframe 可能尚未加载）
    function syncGiscusTheme() {
      var t = document.documentElement.getAttribute('data-theme');
      var theme = t === 'light' ? 'light' : 'dark';
      var iframe = document.querySelector('.giscus-frame') || document.querySelector('iframe[src*="giscus"]');
      if (iframe && iframe.contentWindow) {
        iframe.contentWindow.postMessage(
          { giscus: { setConfig: { theme: theme } } },
          'https://giscus.app'
        );
        return true;
      }
      return false;
    }

    new MutationObserver(function() {
      if (syncGiscusTheme()) return;
      var retries = 0;
      var timer = setInterval(function() {
        retries++;
        if (syncGiscusTheme() || retries >= 5) {
          clearInterval(timer);
        }
      }, 1000);
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  })();
</script>
