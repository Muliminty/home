---
import type { MomentUpdate } from '../lib/content/types';

interface Props {
  moment: MomentUpdate;
}

const { moment } = Astro.props;
const base = import.meta.env.BASE_URL;
const detailUrl = `${base}moments/${moment.number}/`;
const imagesJson = JSON.stringify(moment.images);
---

<a href={detailUrl} class="moment-card">
  <div class="inner">
    <time class="time">{moment.publishedAt.slice(0, 10)}</time>
    {moment.tags?.length > 0 && (
      <div class="labels">
        {moment.tags.slice(0, 3).map(label => (
          <span class="label">{label}</span>
        ))}
      </div>
    )}
    <p class="body">{moment.text}</p>
    {moment.images.length > 0 && (
      <div class="imgs" data-moment-images={imagesJson}>
        {moment.images.slice(0, 4).map((img, i) => (
          <img class="thumb" src={img.src} alt={img.alt} loading="lazy" data-img-index={i} />
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .moment-card {
    --mx: 0.5; --my: 0.5; --sx: 50%; --sy: 50%;
    position: relative; display: block;
    padding: 20px 24px; margin-bottom: 12px;
    background: rgba(255, 255, 255, 0.45);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 10px;
    text-decoration: none; color: inherit;
    transform:
      perspective(800px)
      rotateY(calc((var(--mx) - 0.5) * 8deg))
      rotateX(calc((var(--my) - 0.5) * -6deg))
      translateY(0px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    transition:
      transform 0.15s ease-out,
      box-shadow 0.25s ease-out,
      background 0.25s ease-out,
      border-color 0.25s ease-out;
    z-index: 0;
  }
  .moment-card:hover {
    transform:
      perspective(800px)
      rotateY(calc((var(--mx) - 0.5) * 8deg))
      rotateX(calc((var(--my) - 0.5) * -6deg))
      translateY(-3px);
    background: rgba(255, 255, 255, 0.8);
    border-color: rgba(0, 0, 0, 0.12);
    z-index: 2;
  }

  /* spotlight — ::before */
  .moment-card::before {
    content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 1;
    opacity: 0;
    background: radial-gradient(
      400px circle at var(--sx) var(--sy),
      rgba(255, 255, 255, 0.5),
      transparent 50%
    );
    border-radius: 10px;
    transition: opacity 0.35s ease;
  }
  .moment-card:hover::before { opacity: 1; }

  /* 阴影增强 — ::after，跟随鼠标方向 */
  .moment-card::after {
    content: ''; position: absolute; inset: 0; pointer-events: none; z-index: -1;
    opacity: 0;
    border-radius: 10px;
    box-shadow:
      calc((var(--mx) - 0.5) * 16px) calc((var(--my) - 0.5) * 12px) 28px rgba(0, 0, 0, 0.08);
    transition: opacity 0.25s ease;
  }
  .moment-card:hover::after { opacity: 1; }

  .inner { position: relative; z-index: 2; }

  .time {
    font-size: 11px; color: var(--text-muted);
    font-family: var(--font-mono);
    margin-bottom: 6px; transition: color 0.25s ease;
  }
  .moment-card:hover .time { color: var(--text-secondary); }

  .labels { display: flex; gap: 4px; margin-bottom: 8px; }
  .label {
    font-size: 10px; padding: 1px 6px; border-radius: 4px;
    background: var(--tag-bg); color: var(--text-muted);
    border: 1px solid var(--border);
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease;
  }
  .moment-card:hover .label {
    background: rgba(37, 99, 235, 0.08);
    border-color: rgba(37, 99, 235, 0.2);
    color: var(--accent);
  }

  .body { font-size: 14px; line-height: 1.7; }

  .imgs { display: flex; gap: 6px; margin-top: 10px; position: relative; z-index: 2; }
  .thumb {
    width: 72px; height: 72px; object-fit: cover; border-radius: 6px;
    background: #f5f5f7;
    transform: translateZ(10px);
    transition: transform 0.25s ease-out;
  }
  .moment-card:hover .thumb { transform: translateZ(10px) scale(1.04); }

</style>
<style is:global>
  /* Lightbox (global — DOM created dynamically by JS) */
  .moment-lightbox {
    position: fixed; inset: 0; z-index: 100000;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0, 0, 0, 0);
    opacity: 0;
    transition: background 0.35s ease, opacity 0.35s ease;
    pointer-events: none;
    cursor: default;
  }
  .moment-lightbox.open {
    background: rgba(0, 0, 0, 0.9);
    opacity: 1;
    pointer-events: auto;
  }
  .moment-lightbox .lb-img-wrap {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    max-width: 92vw; max-height: 90vh;
    transform: scale(0.9);
    transition: transform 0.35s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .moment-lightbox.open .lb-img-wrap { transform: scale(1); }
  .moment-lightbox .lb-img {
    max-width: 92vw; max-height: 88vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 4px 40px rgba(0, 0, 0, 0.5);
  }
  .moment-lightbox .lb-close {
    position: absolute; top: 20px; right: 24px;
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 50%;
    cursor: pointer;
    z-index: 2;
    transition: background 0.2s ease, color 0.2s ease;
    line-height: 1;
  }
  .moment-lightbox .lb-close:hover { background: rgba(255, 255, 255, 0.18); color: #fff; }
  .moment-lightbox .lb-nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; color: rgba(255, 255, 255, 0.75);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    cursor: pointer;
    z-index: 2;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .moment-lightbox .lb-nav:hover { background: rgba(255, 255, 255, 0.16); color: #fff; }
  .moment-lightbox .lb-nav.hidden { display: none; }
  .lb-prev { left: 24px; }
  .lb-next { right: 24px; }
  .moment-lightbox .lb-counter {
    position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
    font-size: 12px; color: rgba(255, 255, 255, 0.45);
    font-family: var(--font-mono);
    z-index: 2;
  }
  @media (max-width: 600px) {
    .moment-lightbox .lb-close { top: 12px; right: 12px; width: 36px; height: 36px; font-size: 20px; }
    .moment-lightbox .lb-nav { width: 36px; height: 36px; font-size: 16px; }
    .lb-prev { left: 8px; }
    .lb-next { right: 8px; }
    .moment-lightbox .lb-img { max-width: 98vw; max-height: 82vh; }
  }
</style>
<style>
  @media (prefers-color-scheme: dark) {
    .moment-card {
      background: rgba(41, 37, 36, 0.45);
      border-color: rgba(255, 255, 255, 0.06);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
    .moment-card:hover {
      background: rgba(41, 37, 36, 0.82);
      border-color: rgba(255, 255, 255, 0.12);
    }
    .moment-card::before {
      background: radial-gradient(
        400px circle at var(--sx) var(--sy),
        rgba(96, 165, 250, 0.08),
        transparent 50%
      );
    }
    .moment-card::after {
      box-shadow:
        calc((var(--mx) - 0.5) * 16px) calc((var(--my) - 0.5) * 12px) 28px rgba(0, 0, 0, 0.35);
    }
  }
</style>

<script>
  (function() {
    // 3D tilt
    document.querySelectorAll('.moment-card').forEach(function(card) {
      card.addEventListener('mousemove', function(e) {
        var r = card.getBoundingClientRect();
        var x = e.clientX - r.left;
        var y = e.clientY - r.top;
        card.style.setProperty('--mx', (x / r.width).toFixed(3));
        card.style.setProperty('--my', (y / r.height).toFixed(3));
        card.style.setProperty('--sx', x + 'px');
        card.style.setProperty('--sy', y + 'px');
      });
      card.addEventListener('mouseleave', function() {
        card.style.setProperty('--mx', '0.5');
        card.style.setProperty('--my', '0.5');
      });
    });

    // Shared lightbox builder (called once, reused across cards)
    function getLightbox() {
      var lb = document.querySelector('.moment-lightbox');
      if (!lb) {
        lb = document.createElement('div');
        lb.className = 'moment-lightbox';
        lb.innerHTML =
          '<button class="lb-close" aria-label="关闭">&times;</button>' +
          '<button class="lb-nav lb-prev" aria-label="上一张">&lsaquo;</button>' +
          '<button class="lb-nav lb-next" aria-label="下一张">&rsaquo;</button>' +
          '<div class="lb-img-wrap"><img class="lb-img" src="" alt="" /></div>' +
          '<span class="lb-counter"></span>';
        document.body.appendChild(lb);

        var closeBtn = lb.querySelector('.lb-close');
        var prevBtn = lb.querySelector('.lb-prev');
        var nextBtn = lb.querySelector('.lb-next');
        closeBtn.addEventListener('click', function() { hideLightbox(lb); });
        prevBtn.addEventListener('click', function() { navLightbox(lb, -1); });
        nextBtn.addEventListener('click', function() { navLightbox(lb, 1); });
        lb.addEventListener('click', function(e) {
          if (e.target === lb) hideLightbox(lb);
        });
        document.addEventListener('keydown', function(e) {
          if (!lb.classList.contains('open')) return;
          if (e.key === 'Escape') hideLightbox(lb);
          if (e.key === 'ArrowLeft') navLightbox(lb, -1);
          if (e.key === 'ArrowRight') navLightbox(lb, 1);
        });
      }
      return lb;
    }

    function showLightbox(lb, images, idx) {
      lb._images = images;
      lb._currentIdx = idx;
      var imgEl = lb.querySelector('.lb-img');
      var prevBtn = lb.querySelector('.lb-prev');
      var nextBtn = lb.querySelector('.lb-next');
      var counter = lb.querySelector('.lb-counter');
      imgEl.src = images[idx].src;
      imgEl.alt = images[idx].alt;
      lb.classList.add('open');
      document.body.style.overflow = 'hidden';
      var dot = document.querySelector('.cursor-dot');
      var trail = document.querySelector('.cursor-trail');
      if (dot) dot.style.display = 'none';
      if (trail) trail.style.display = 'none';
      prevBtn.classList.toggle('hidden', idx === 0);
      nextBtn.classList.toggle('hidden', idx === images.length - 1);
      counter.textContent = images.length > 1 ? (idx + 1) + ' / ' + images.length : '';
    }

    function hideLightbox(lb) {
      lb.classList.remove('open');
      document.body.style.overflow = '';
      var dot = document.querySelector('.cursor-dot');
      var trail = document.querySelector('.cursor-trail');
      if (dot) dot.style.display = '';
      if (trail) trail.style.display = '';
    }

    function navLightbox(lb, delta) {
      var images = lb._images || [];
      var next = (lb._currentIdx || 0) + delta;
      if (next >= 0 && next < images.length) showLightbox(lb, images, next);
    }

    // Attach click to thumbnails: open lightbox, don't navigate
    document.querySelectorAll('.moment-card .imgs').forEach(function(imgsContainer) {
      var images = JSON.parse(imgsContainer.getAttribute('data-moment-images') || '[]');
      if (!images.length) return;
      imgsContainer.querySelectorAll('.thumb').forEach(function(thumb) {
        thumb.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          var idx = parseInt(thumb.getAttribute('data-img-index') || '0', 10);
          showLightbox(getLightbox(), images, idx);
        });
      });
    });
  })();
</script>
